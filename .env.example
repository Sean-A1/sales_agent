# ============================================================
#  .env.example  –  copy to .env and fill in your values
# ============================================================

# ── PDF Parsing ──────────────────────────────────────────────
# Get your key at https://cloud.llamaindex.ai
# Either variable name is accepted; LLAMAPARSE_API_KEY takes priority.
LLAMAPARSE_API_KEY=your-llamaparse-key-here
# LLAMA_CLOUD_API_KEY=your-key-here   # alternative / fallback name

# ── LLM (optional) ───────────────────────────────────────────
# If absent, the pipeline runs in "chunks-only" mode (no LLM cost).
OPENAI_API_KEY=your-openai-key-here

# ── LLM tuning (cost control) ────────────────────────────────
# OPENAI_MODEL=gpt-4o-mini   # cheapest capable model
# MAX_TOKENS=256              # hard cap on LLM response length
# TEMPERATURE=0.1             # lower = more deterministic

# ── Retrieval budget (cost control) ──────────────────────────
# TOP_K=4                     # chunks fetched from vector store
# MAX_CONTEXT_CHUNKS=4        # chunks actually sent to LLM
# MAX_CHUNK_CHARS=1200        # each chunk is truncated to this
# MAX_QUERY_CHARS=500         # long questions are trimmed here

# ── Chunking ─────────────────────────────────────────────────
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=100

# ── Embeddings (local, no API key needed) ────────────────────
# EMBEDDING_MODEL=all-MiniLM-L6-v2
