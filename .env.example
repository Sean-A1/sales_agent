# ==========================================
# LLM
# ==========================================
OPENAI_API_KEY=

# ==========================================
# Neo4j AuraDB
# ==========================================
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# ==========================================
# Qdrant
# 로컬 Docker: URL만, API key 비워도 됨
# Cloud: URL + API key 둘 다
# ==========================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ==========================================
# PostgreSQL
# 로컬 Docker 환경변수 (docker-compose.yml 연동)
# ==========================================
POSTGRES_USER=sales_agent
POSTGRES_PASSWORD=
POSTGRES_DB=sales_agent
DATABASE_URL=postgresql://sales_agent:<POSTGRES_PASSWORD>@localhost:5432/sales_agent

