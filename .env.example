# ==========================================
# LLM
# ==========================================
OPENAI_API_KEY=


# ==========================================
# Neo4j AuraDB
# ==========================================
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=


# ==========================================
# Qdrant
# 로컬 Docker: URL만, API key 비워도 됨
# Cloud: URL + API key 둘 다
# ==========================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=


# ==========================================
# PostgreSQL
# 로컬 Docker 기본값 아래 참고
# ==========================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/sales_agent


